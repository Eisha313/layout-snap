{
  "name": "layout-snap",
  "version": "0.1.0",
  "description": "A lightweight JavaScript library for generating responsive CSS Grid and Flexbox layouts from simple configuration objects",
  "main": "dist/layout-snap.cjs.js",
  "module": "dist/layout-snap.esm.js",
  "browser": "dist/layout-snap.umd.js",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "css",
    "grid",
    "flexbox",
    "layout",
    "responsive",
    "generator"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.0",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "rollup": "^3.29.0"
  }
}
